        "eslint:fix": "eslint --fix .",
        "lint": "pnpm eslint:check && pnpm stylelint:check",
        "lint:fix": "pnpm eslint:fix && pnpm stylelint:fix",
        "lint:check": "pnpm eslint:check && pnpm stylelint:check",
        "stylelint:check": "pnpm stylelint:check:scss",
        "stylelint:check:css": "stylelint \"**/*.css\"",
        "stylelint:check:scss": "stylelint \"**/*.scss\"",
        "stylelint:check:vue": "stylelint \"**/*.vue\"",
        "stylelint:fix": "pnpm stylelint:fix:scss",
        "stylelint:fix:css": "stylelint \"**/*.css\" --fix",
        "stylelint:fix:scss": "stylelint  \"**/*.scss\" --fix",
        "stylelint:fix:vue": "stylelint \"**/*.vue\" --fix",
        "db:generate": "nuxi db generate",
        "db:migrate": "nuxi db migrate",
        "db:mark-as-migrated": "nuxi db mark-as-migrated",
        "db:drop": "nuxi db drop",
        "db:drop-all": "nuxi db drop-all",
        "db:squash": "nuxi db squash",
        "db:sql": "nuxi db sql",
        "test:nuxt": "vitest run --project nuxt",
        "test:unit": "vitest run --project unit",
        "test:e2e": "vitest run --project e2e",
        "test:all": "vitest",
        "test:coverage": "vitest run --coverage --project unit --project nuxt",
        "test:dev": "vitest --watch",
        "test": "pnpm test:unit",
        "script:backup": "node ./scripts/backup.js",
        "script:release": "node ./scripts/release.js",
        "version:patch": "pnpm release -- --release-as patch",
        "version:minor": "pnpm release -- --release-as minor",
        "version:major": "pnpm release -- --release-as major",
        "release:first": "pnpm release -- --first-release",
        "release": "commit-and-tag-version"
    },
