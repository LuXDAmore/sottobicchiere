{
    "name": "@luxdamore/sottobicchiere",
    "version": "0.1.0",
    "description": "Sottobicchiere — PWA gaming per bar e locali con tavoli: giochi multiplayer, QR code, sessioni anonime e sfide venue",
    "author": "LuXDAmore <lucabelli@msn.com>",
    "license": "MIT",
    "homepage": "https://github.com/luxdamore/sottobicchiere",
    "keywords": [
        "sottobicchiere",
        "pwa",
        "gaming",
        "bar",
        "giochi",
        "multiplayer",
        "qr-code",
        "nuxt",
        "vue",
        "typescript"
    ],
    "contributors": [
        {
            "name": "Luca Iaconelli <lucabelli@msn.com> (https://lucaiaconelli.it)"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/luxdamore/sottobicchiere"
    },
    "bugs": {
        "url": "https://github.com/luxdamore/sottobicchiere/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "nuxt.config.js",
        ".nuxt",
        ".output",
        "dist"
    ],
    "type": "module",
    "main": "nuxt.config.js",
    "scripts": {
        "vercel": "vercel",
        "check:eslint-config": "cross-env TIMING=1 pnpm eslint:fix",
        "typecheck": "cross-env NODE_NO_WARNINGS=1 nuxi typecheck",
        "analyze": "nuxi analyze",
        "build:profile": "nuxi build --profile",
        "build": "nuxi build",
        "nuxt:upgrade": "nuxi upgrade --force",
        "dev": "nuxi dev -o",
        "serve": "pnpm dev",
        "generate": "nuxi generate",
        "prepreview": "pnpm build",
        "preview": "nuxi preview",
        "clean": "nuxi cleanup",
        "prepare": "cross-env NODE_NO_WARNINGS=1 nuxi prepare",
        "start": "nuxi start",
        "eslint:check": "eslint .",
        "eslint:fix": "eslint --fix .",
        "lint": "pnpm eslint:check && pnpm stylelint:check",
        "lint:fix": "pnpm eslint:fix && pnpm stylelint:fix",
        "lint:check": "pnpm eslint:check && pnpm stylelint:check",
        "stylelint:check": "pnpm stylelint:check:css",
        "stylelint:check:css": "stylelint \"**/*.css\" --allow-empty-input",
        "stylelint:check:scss": "stylelint \"**/*.scss\" --allow-empty-input",
        "stylelint:check:vue": "stylelint \"**/*.vue\" --allow-empty-input",
        "stylelint:fix": "pnpm stylelint:fix:css",
        "stylelint:fix:css": "stylelint \"**/*.css\" --fix --allow-empty-input",
        "stylelint:fix:scss": "stylelint  \"**/*.scss\" --fix --allow-empty-input",
        "stylelint:fix:vue": "stylelint \"**/*.vue\" --fix --allow-empty-input",
        "db:start": "supabase start",
        "db:stop": "supabase stop",
        "db:push": "supabase db push",
        "db:reset": "supabase db reset",
        "db:diff": "supabase db diff",
        "db:types": "supabase gen types typescript --local > shared/types/database.ts",
        "db:types:check": "supabase gen types typescript --local | diff shared/types/database.ts - || (echo 'DB types drift: esegui pnpm db:types' && exit 1)",
        "db:bootstrap": "node scripts/build-bootstrap-sql.mjs",
        "db:bootstrap:check": "node scripts/build-bootstrap-sql.mjs && git diff --exit-code supabase/bootstrap_all.sql || (echo 'bootstrap_all.sql non rigenerato: esegui pnpm db:bootstrap' && exit 1)",
        "test:nuxt": "vitest run --project nuxt",
        "test:unit": "vitest run --project unit",
        "test:e2e": "vitest run --project e2e",
        "test:all": "vitest",
        "test:coverage": "vitest run --coverage --project unit --project nuxt",
        "test:dev": "vitest --watch",
        "test": "pnpm test:unit",
        "script:backup": "node ./scripts/backup.js",
        "script:release": "node ./scripts/release.js",
        "version:patch": "pnpm release -- --release-as patch",
        "version:minor": "pnpm release -- --release-as minor",
        "version:major": "pnpm release -- --release-as major",
        "release:first": "pnpm release -- --first-release",
        "release": "commit-and-tag-version"
    },
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
    "dependencies": {
        "@iconify-json/lucide": "^1.2.114",
        "@internationalized/date": "^3.12.2",
        "@nuxt/eslint": "^1.16.0",
        "@nuxt/fonts": "latest",
        "@nuxt/hints": "^1.1.3",
        "@nuxt/icon": "latest",
        "@nuxt/image": "latest",
        "@nuxt/kit": "4.4.8",
        "@nuxt/scripts": "latest",
        "@nuxt/ui": "^4.9.0",
        "@nuxtjs/html-validator": "latest",
        "@nuxtjs/i18n": "^10.4.0",
        "@nuxtjs/mdc": "^0.22.0",
        "@nuxtjs/seo": "^5.3.0",
        "@nuxtjs/supabase": "^2.0.9",
        "@pinia/nuxt": "^0.11.3",
        "@supabase/supabase-js": "^2.108.2",
        "@vercel/speed-insights": "^2.0.0",
        "@vite-pwa/assets-generator": "^1.0.2",
        "@vite-pwa/nuxt": "^1.1.1",
        "@vueuse/integrations": "latest",
        "@vueuse/motion": "^3.0.3",
        "@vueuse/nuxt": "latest",
        "lenis": "^1.3.23",
        "nuxi": "^3.36.0",
        "nuxt": "^4.4.8",
        "nuxt-qrcode": "^0.4.10",
        "nuxt-security": "^2.6.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "sass": "^1.101.0",
        "tailwindcss": "^4.3.1",
        "unstorage": "latest",
        "vue": "^3.5.38",
        "vue-router": "^5.1.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^8.0.1",
        "@commitlint/cli": "^21.1.0",
        "@commitlint/config-conventional": "^21.1.0",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@eslint/compat": "^2.1.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@nuxt/test-utils": "^4.0.3",
        "@nuxt/types": "^2.18.1",
        "@playwright/test": "^1.61.1",
        "@shikijs/engine-javascript": "^4.2.0",
        "@shikijs/engine-oniguruma": "^4.2.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@stylistic/stylelint-plugin": "^5.2.0",
        "@testing-library/vue": "^8.1.0",
        "@tsconfig/recommended": "^1.0.13",
        "@types/node": "^26.0.0",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/eslint-plugin": "^1.6.20",
        "@vue/test-utils": "^2.4.11",
        "commit-and-tag-version": "^12.7.3",
        "consola": "^3.4.2",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-compat": "^7.0.2",
        "eslint-plugin-depend": "^1.5.0",
        "eslint-plugin-import-newlines": "^2.0.0",
        "eslint-plugin-import-x": "^4.17.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jsdoc": "^63.0.7",
        "eslint-plugin-n": "^18.1.0",
        "eslint-plugin-nuxt": "^4.0.0",
        "eslint-plugin-perfectionist": "^5.9.1",
        "eslint-plugin-playwright": "^2.10.4",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-unicorn": "^68.0.0",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "playwright-core": "^1.61.1",
        "prettier": "^3.8.4",
        "prettier-eslint": "^17.1.1",
        "prettier-stylelint": "^0.4.2",
        "rollup-plugin-sbom": "^3.2.3",
        "stylelint": "^17.13.0",
        "stylelint-config-clean-order": "^10.0.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recommended": "^18.0.0",
        "stylelint-config-recommended-scss": "^17.0.1",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-sass-guidelines": "^13.0.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-no-unsupported-browser-features": "^8.1.1",
        "stylelint-order": "^8.1.1",
        "stylelint-scss": "^7.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vercel": "^54.16.0",
        "vite-plugin-eslint": "^1.8.1",
        "vitest": "^4.1.9",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5",
        "wrangler": "^4.104.0",
        "zip-a-folder": "^6.1.1"
    }
}
