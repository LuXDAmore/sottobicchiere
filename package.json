        "generate": "nuxi generate",
        "prepreview": "pnpm build",
        "preview": "nuxi preview",
        "clean": "nuxi cleanup",
        "prepare": "cross-env NODE_NO_WARNINGS=1 nuxi prepare",
        "start": "nuxi start",
