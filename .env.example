# Sottobicchiere — Environment Variables
# Copia questo file in .env (o usa: vercel env pull .env)

# ── App ────────────────────────────────────────────────────────
NUXT_APP_BASE_URL="/"
NUXT_APP_ENV="development"
NUXT_SITE_NAME="Sottobicchiere"
NUXT_SITE_DESCRIPTION="Giochi da tavolo per il tuo locale"
NUXT_SITE_URL="https://localhost:3000"
NUXT_PUBLIC_SITE_URL="https://localhost:3000"

# ── Colori brand (override per venue personalizzato) ──────────
# Hex del colore primario e accento, separati da virgola
NUXT_COLORS="#4F46E5,#F59E0B"

# ── OG Image ──────────────────────────────────────────────────
NUXT_OG_IMAGE_SECRET=""

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Project Settings → API. URL e publishable key sono esposte al
# client; la secret (service role) è SOLO server-side, non esporla mai.
NUXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="<publishable-key>"
NUXT_SUPABASE_SECRET_KEY="<service-role-secret-key>"

# Ricorda di abilitare in dashboard (o via supabase/config.toml in locale):
#  • Authentication → Providers → Anonymous sign-ins
#  • Realtime → disattiva "Allow public access" (i channel sono privati via RLS)

# ── Node ──────────────────────────────────────────────────────
# ATTENZIONE: solo per debug locale con certificati mkcert non trustati.
# NON copiare in produzione o staging — disabilita la verifica TLS per tutte le request Node.
# NODE_TLS_REJECT_UNAUTHORIZED="0"
