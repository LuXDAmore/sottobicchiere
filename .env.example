# Sottobicchiere — Environment Variables
# Copia questo file in .env (o usa: vercel env pull .env)

# ── App ────────────────────────────────────────────────────────
NUXT_APP_BASE_URL="/"
NUXT_APP_ENV="development"
NUXT_SITE_NAME="Sottobicchiere"
NUXT_SITE_DESCRIPTION="Giochi da tavolo per il tuo locale"
NUXT_SITE_URL="https://localhost:3000"
NUXT_PUBLIC_SITE_URL="https://localhost:3000"

# ── Colori brand (override per venue personalizzato) ──────────
# Hex del colore primario e accento, separati da virgola
NUXT_COLORS="#4F46E5,#F59E0B"

# ── OG Image ──────────────────────────────────────────────────
NUXT_OG_IMAGE_SECRET=""

# ── Neon PostgreSQL ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host-unpooled/dbname?sslmode=require"
PGDATABASE="neondb"
PGHOST="host-pooler.neon.tech"
PGHOST_UNPOOLED="host.neon.tech"
PGPASSWORD="password"
PGUSER="user"
POSTGRES_DATABASE="neondb"
POSTGRES_HOST="host-pooler.neon.tech"
POSTGRES_PASSWORD="password"
POSTGRES_URL="postgresql://user:password@host/dbname?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host-unpooled/dbname?sslmode=require"
POSTGRES_USER="user"
NEON_PROJECT_ID=""

# ── Vercel Redis (game state KV) ──────────────────────────────
REDIS_URL="redis://default:password@host:port"

# ── Vercel Blob (asset venue) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ── Cron ──────────────────────────────────────────────────────
CRON_SECRET=""

# ── Node ──────────────────────────────────────────────────────
NODE_TLS_REJECT_UNAUTHORIZED="0"
